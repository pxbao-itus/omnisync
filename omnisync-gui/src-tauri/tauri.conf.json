{
  "$schema": "https://raw.githubusercontent.com/nicedoc/schemas/main/tauri.schema.json",
  "productName": "OmniSync",
  "version": "0.1.0",
  "identifier": "com.omnisync.app",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "OmniSync",
        "width": 960,
        "height": 680,
        "center": true,
        "resizable": true,
        "minWidth": 700,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}